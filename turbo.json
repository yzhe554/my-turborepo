{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "main": {
      "cache": false
    },
    "sub-task-1": {
      "cache": true,
      "outputs": ["generated/**"]
    },
    "sub-task-2": {
      "cache": true
    }
  },
  "remoteCache": {
		"enabled": true,
		"teamSlug": "Test",
		"apiUrl": ""
	}
}
